# Build output
bin/
obj/
[Dd]ebug/
[Rr]elease/
*.user

# Rider / VS
.idea/
.vs/

# Per-dev working notes (auto-loaded by Claude Code; free-form, not a team doc).
# PROJECT_PLAN.md is the committed authoritative log — CLAUDE.md just points to it.
CLAUDE.md

# Secrets / operator-provided BYO data (NEVER commit)
# The XOR cipher table is intentionally kept out of git history (see PROJECT_PLAN.md).
xor-table*.bin
xor-table*.hex
appsettings.*.Local.json
*.env
.env

# Reference captures (may contain session data)
*.pcap
*.pcapng

# Loadout templates that are operator-local (the schema + samples are tracked,
# operator instances are not)
templates/local/

# Local session handover (orientation notes, references creds indirectly)
handover.md

# Dev helper scripts (local conveniences, not part of the build)
start-host.ps1
host.log
host-out.log
host-err.log
